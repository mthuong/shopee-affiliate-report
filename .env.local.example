# Supabase — get these from Project Settings > API
# URL: Project Settings > API > Project URL
# Publishable key: Project Settings > API > Project API keys > Publishable (replaces legacy anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Secret key — Project Settings > API > Project API keys > service_role (secret)
# Server-only. Bypasses RLS. NEVER expose to the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini — get free API key at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key

# Feature flags
# Set to "false" to disable the user-confirmed crop step before parsing
# (revert to pre-cropping behavior). Any other value (or unset) = enabled.
NEXT_PUBLIC_ENABLE_CROP_CONFIRM=true
